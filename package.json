{
  "name": "@betting/root",
  "private": true,
  "workspaces": [
    "frontend",
    "services/core",
    "services/odds"
  ],
  "engines" : {
    "npm" : "~11.12.1",
    "node" : "25"
  },
  "packageManager": "npm@11.12.1",
  "scripts": {
    "build": "turbo run build --continue",
    "typecheck": "turbo run typecheck --continue",
    "hooks:setup": "mkdir -p .git/hooks && cp .githooks/pre-* .git/hooks/ && chmod +x .git/hooks/pre-*",
    "up:dev": "docker compose up -d postgres redis tigerbeetle",
    "init": "npm install && turbo run init --continue"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
