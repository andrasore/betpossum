{
  "name": "@betting/root",
  "private": true,
  "workspaces": [
    "frontend",
    "services/core",
    "services/odds",
    "services/wallet"
  ],
  "packageManager": "npm@11.12.1",
  "scripts": {
    "build": "turbo run build --continue",
    "typecheck": "turbo run typecheck --continue",
    "prepare": "mkdir -p .git/hooks && cp .githooks/pre-* .git/hooks/ && chmod +x .git/hooks/pre-*",
    "init": "npm install && turbo run init --continue"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
