# Comma-separated list of enabled providers; each runs its own poll loop.
# Options: mock, theoddsapi, apifootball
ODDS_PROVIDERS=mock
ODDS_STORAGE=postgres
POLL_INTERVAL_SECONDS=30

# The Odds API (provider: theoddsapi)
THE_ODDS_API_KEY=your_key_here
# THE_ODDS_API_SPORTS=soccer_epl,basketball_nba,americanfootball_nfl

# API-Football / api-sports.io (provider: apifootball)
APIFOOTBALL_API_KEY=
APIFOOTBALL_LEAGUES=39
APIFOOTBALL_SEASON=2023
APIFOOTBALL_UPCOMING=5
