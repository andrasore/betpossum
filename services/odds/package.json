{
  "name": "@betting/odds",
  "version": "0.1.0",
  "scripts": {
    "init": "uv sync --extra dev",
    "schema:gen": "mkdir -p ./src/generated && .venv/bin/datamodel-codegen --input ../../schemas/json --input-file-type jsonschema --output src/generated --output-model-type pydantic_v2.BaseModel --target-python-version 3.14 --enum-field-as-literal all --disable-timestamp",
    "typecheck": ".venv/bin/pyright src/",
    "lint": ".venv/bin/ruff check && .venv/bin/ruff format --check",
    "lint:fix": ".venv/bin/ruff format",
    "test": ".venv/bin/pytest"
  }
}
