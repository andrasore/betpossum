# Read store for the stats projection (its own database).
DATABASE_URL=postgresql://betting:betting_dev@localhost:5432/stats

# Event bus carrying the durable bets.settled domain event.
RABBITMQ_URL=amqp://betting:betting_dev@localhost:5672

# Keycloak (JWT verification for the per-user /stats/me endpoints).
KEYCLOAK_INTERNAL_URL=http://localhost:8080/kc
KEYCLOAK_ISSUER_URL=http://localhost:8080/kc/realms/betting
KEYCLOAK_REALM=betting

# Leaderboard tuning.
LEADERBOARD_LIMIT=7
LEADERBOARD_MIN_SETTLED=3
