{
  "$schema": "https://turbo.build/schema.json",
  "//": "NOTE: pnpm install is managed separately from \"init\"",
  "tasks": {
    "init": {
      "inputs": ["pyproject.toml"],
      "outputs": [".venv/**"]
    },
    "build": {
      "dependsOn": ["init"],
      "inputs": ["src/**"],
      "outputs": ["dist/**", ".next/**"]
    },
    "proto:gen": {
      "inputs": ["../../proto/**/*.proto"],
      "outputs": ["src/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["build"],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.py",
        "tsconfig.json",
        "pyproject.toml"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["build"],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.py",
        "tsconfig.json",
        "pyproject.toml",
        "biome.jsonc"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "jest.config.js", "tsconfig.json"],
      "outputs": []
    },
    "format": {
      "inputs": [
        "biome.jsonc"
      ]
    }
  }
}
