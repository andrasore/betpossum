{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "inputs": ["../../proto/**/*.proto"],
      "outputs": ["src/**/*_pb2.py", "src/**/*_pb2.pyi"]
    },
    "typecheck": {
      "dependsOn": ["build"],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.py",
        "tsconfig.json",
        "pyproject.toml"
      ],
      "outputs": []
    },
    "init": {
      "cache": false
    }
  }
}
