{
  "$schema": "https://turbo.build/schema.json",
  "//": "NOTE: pnpm install and venv is managed separately from \"init\" because it collides with Github Actions' cache",
  "tasks": {
    "init": {
      "inputs": ["pyproject.toml"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["init"],
      "inputs": ["src/**"],
      "outputs": ["dist/**", ".next/**"]
    },
    "schema:gen": {
      "inputs": ["../../schemas/**/*.json"],
      "outputs": ["src/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["build"],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.py",
        "tsconfig.json",
        "pyproject.toml"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["build"],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.py",
        "tsconfig.json",
        "pyproject.toml",
        "biome.jsonc"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "jest.config.js",
        "vitest.config.ts",
        "tsconfig.json"
      ],
      "outputs": []
    },
    "format": {
      "inputs": [
        "biome.jsonc"
      ]
    }
  }
}
